{
  "name": "counsel-admin-v2",
  "description": "상담 관리 시스템",
  "author": {
    "name": "Zeniel"
  },
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "vite preview",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run --passWithNoTests",
    "postinstall": "node scripts/ensure-electron-install.cjs",
    "electron:ensure": "node scripts/ensure-electron-install.cjs",
    "electron:dev": "concurrently -k \"cross-env NODE_ENV=development ELECTRON_RENDERER_URL=http://localhost:5181 vite --port 5181 --strictPort\" \"wait-on tcp:127.0.0.1:5181 && cross-env NODE_ENV=development ELECTRON_RENDERER_URL=http://localhost:5181 electron .\"",
    "electron:build": "vite build --config vite.electron.config.ts && electron-builder --config electron-builder.yml",
    "electron:build:win": "vite build --config vite.electron.config.ts && electron-builder --win --config electron-builder.yml",
    "electron:build:mac": "vite build --config vite.electron.config.ts && electron-builder --mac --config electron-builder.yml",
    "electron:build:linux": "vite build --config vite.electron.config.ts && electron-builder --linux --config electron-builder.yml",
    "electron:preview": "cross-env NODE_ENV=production electron ."
  },
  "dependencies": {
